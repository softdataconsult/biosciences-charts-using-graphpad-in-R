)
cat("Saved:", a, "\n")
}
# ============================================================
# COMBINED 3x3 PANEL
# ============================================================
plots <- lapply(assay_names, make_plot)
panel <- wrap_plots(plots, ncol = 3) +
plot_annotation(
caption = "Data are presented as Mean ± SD (n = 5). Different letters indicate significant difference at p < 0.05.\nGroup 1 = control; Group 2 = AlCl\u2083 (0.1 mg/g diet); Group 3 = AlCl\u2083 + AESS (0.25 mg/g); Group 4 = AlCl\u2083 + AESS (0.5 mg/g); Group 5 = AESS (0.4 mg/g) only.",
theme = theme(plot.caption = element_text(size = 7, hjust = 0))
)
ggsave(
filename = "/home/claude/plots/Fig_ALL_panel.png",
plot     = panel,
width    = 15, height = 12, dpi = 300, bg = "white"
)
